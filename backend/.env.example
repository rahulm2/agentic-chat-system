# ── SECRETS (required, no defaults — must be set before starting) ──────────────

# OpenAI API key — used for chat completions and TTS audio generation.
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# JWT signing secret — must be at least 32 random characters.
# Generate one with: openssl rand -base64 32
JWT_SECRET=change-me-to-at-least-32-random-characters-long

# ── INFRASTRUCTURE (required) ───────────────────────────────────────────────────

# PostgreSQL connection string.
# When using docker compose this is overridden automatically in the environment block.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentchat

# ── SERVER (optional — safe defaults provided) ──────────────────────────────────

# HTTP port the backend listens on. Default: 3000
PORT=3000

# ── AI AGENT (optional — safe defaults provided) ────────────────────────────────

# OpenAI model used for chat completions. Default: gpt-4o
AI_MODEL=gpt-4o

# Maximum agentic loop iterations per request before hard-stopping. Default: 6
MAX_AGENT_STEPS=6

# Per-request timeout in milliseconds before the agent is aborted. Default: 30000
AI_TIMEOUT_MS=30000

# ── TEXT-TO-SPEECH (optional — safe defaults provided) ──────────────────────────

# OpenAI TTS model. Default: tts-1  (tts-1-hd for higher quality, higher cost)
TTS_MODEL=tts-1

# TTS voice. Options: alloy, echo, fable, onyx, nova, shimmer. Default: alloy
TTS_VOICE=alloy

# ── EXTERNAL APIs (optional) ────────────────────────────────────────────────────

# openFDA API key — increases rate limits for drug adverse-event lookups.
# Without a key, requests still work but at lower rate limits.
# Get yours at https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=
